<style>
  .project-container {
    margin: -70px -96px -90px -70px;
    padding: 70px 96px 120px 70px;
    background-color: var(--clave-mustard);
  }

  @media (max-width: 719px) {
    .project-container {
      margin: -70px -47px -90px;
      padding: 70px 47px 120px;
    }
  }
  
  .project-list {
    margin: 0;
    list-style: none;
    flex: 1 0 auto;
  }

  .link-item {
    margin-bottom: 0;
  }

  .link-wrapper {
    display: flex;
    flex-direction: column;
    width: fit-content;
  }

  .link-wrapper::after {
    content: '';
    margin-top: 5px;
    display: block;
    height: 2px;
    background: var(--clave-pink);
  }

  .link-wrapper:hover::after {
    animation: link-hover 0.5s forwards;
  }

  @keyframes link-hover {
    0%   { background: var(--clave-pink); transform: scaleX(1); }
    50%  { background: var(--clave-pink); transform: scaleX(0); }
    51%  { background: var(--clave-yellow); transform: scaleX(0); }
    100% { background: var(--clave-yellow); transform: scaleX(1); }
  }

  .right-arrow-link {
    display: flex;
    font-size: 24px;
    margin: 20px -15px -3px 0;
    text-decoration: none;
    color: var(--clave-green);
  }

  .right-arrow-link::after {
    content: '';
    width: 0;
    height: 0;
    display: block;
    border-top: 15px solid transparent;
    border-bottom: 15px solid transparent;
    border-left: 20px solid transparent;
  }

  .right-arrow-link:hover::after {
    width: 0;
    height: 0;
    margin-left: 20px;
    margin-top: -2px;
    border-top: 15px solid transparent;
    border-bottom: 15px solid transparent;
    border-left: 20px solid var(--clave-green);
    transform: scaleX(0.6) scaleY(0.6);
  }

  @media (min-width: 720px) {
    .right-arrow-link {
      font-size: 32px;
    }

    .right-arrow-link:hover::after {
      margin-top: 5px;
    }
  }
</style>
