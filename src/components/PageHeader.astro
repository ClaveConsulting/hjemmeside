---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Container from './layout/Container.astro';
import ContentColumn from './layout/ContentColumn.astro';
import Ingress from './Ingress.astro';
import { COLOR_CLAVE_PEACH, COLOR_CLAVE_GREEN } from '../colors.js';
import ContainerContent from './layout/ContainerContent.astro';

interface Props {
  title: string;
  ingress?: string;
  image: ImageMetadata;
  imageAlt?: string;
  backgroundColor?: string;
  textColor?: string;
}

const {
  title,
  ingress,
  image,
  imageAlt = "",
  backgroundColor = COLOR_CLAVE_PEACH,
  textColor = COLOR_CLAVE_GREEN,
} = Astro.props;
---
<Container backgroundColor={backgroundColor} textColor={textColor}>
  <div class="page-header-content-wrapper">

  <ContainerContent>
    <ContentColumn style="--column-padding-bottom: 2rem">
      <div class="page-header-content">
        <h1 class="page-header-title">{title}</h1>
        {ingress && <Ingress>{ingress}</Ingress>}
      </div>
    </ContentColumn>
    <Image
      class="page-header-image"
      src={image}
      alt={imageAlt}
      fetchpriority="high"
      loading="eager"
      widths={[600, 900, 1200, 1800]}
    />
  </ContainerContent>
  </div>
</Container>

<style>
  .page-header-content-wrapper {
    padding: 0 0 0 var(--mobile-padding);
  }
  @media (min-width: 720px) {
    .page-header-content-wrapper {
      padding: 0;
    }
  }

  .page-header-title {
    margin-bottom: 1.5rem;
  }

  @media (min-width: 720px) {
    .page-header-title {
      margin-bottom: 4rem;
    }
  }

  .page-header-image {
    display: block;
    width: 100%;
    height: auto;
    margin: 0;
  }

  @media (min-width: 720px) {
    .page-header-image {
      width: 80%;
      margin-left: auto;
    }
  }
</style>
