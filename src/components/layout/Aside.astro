---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<aside class:list={["aside", className]}>
  <slot />
</aside>

<style>
  .aside {
    flex: 1 0 40%;
    order: 1;
    display: flex;
    padding: var(--mobile-padding) 0;
  }

  @media screen and (min-width: 720px) {
    .aside {
      order: 0;
      padding: 0 var(--desktop-padding) 0 0;
    }
  }
</style>
