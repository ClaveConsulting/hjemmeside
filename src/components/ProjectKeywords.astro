---
interface Props {
  keywords: string[];
}

const { keywords } = Astro.props;
---

{keywords && keywords.length > 0 && (
  <div class="keyword-component">
    <h2 class="keyword-header">Prosjektfakta</h2>
    {keywords.map((fact) => <p class="keyword-element">{fact}</p>)}
  </div>
)}

<style>
  .keyword-component {
    margin-left: 4rem;
    width: 13rem;
  }

  .keyword-header {
    font-size: 24px;
    line-height: 1.5;
  }

  .keyword-element {
    font-size: 18px;
    line-height: 1.5;
  }
</style>
