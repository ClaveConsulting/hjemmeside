---
const API_KEY = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
const center = "59.9104989,10.7421957";
---

<iframe
  width="100%"
  height="400"
  style="border:0"
  loading="lazy"
  allowfullscreen
  referrerpolicy="no-referrer-when-downgrade"
  src={`https://www.google.com/maps/embed/v1/place?key=${API_KEY}&q=${center}&zoom=15`}
></iframe>
