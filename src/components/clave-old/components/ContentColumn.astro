---
import Aside from "./Aside.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const hasAside = Astro.slots.has("aside");
---

<div class:list={["layout-wrapper", className]}>
  {hasAside ? (
    <Aside>
      <slot name="aside" />
    </Aside>
  ) : (
    <Aside class="aside--empty" />
  )}
  <section class="section">
    <slot />
  </section>
</div>

<style>
  .layout-wrapper {
    display: flex;
    flex-direction: column;
    padding: 3rem;
  }

  @media screen and (min-width: 720px) {
    .layout-wrapper {
      padding: 6rem;
      flex-direction: row;
    }
  }

  .aside--empty {
    padding: 0;
  }

  .section {
    max-width: 1280px;
  }

  @media screen and (min-width: 720px) {
    .section {
      flex: 1 1 1280px;
    }
  }
</style>
